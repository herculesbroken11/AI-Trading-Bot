# Tastytrade — sandbox (api.cert.tastytrade.com)
TASTYTRADE_CLIENT_ID=your_sandbox_client_id
TASTYTRADE_CLIENT_SECRET=your_sandbox_client_secret
TASTYTRADE_REDIRECT_URI=https://hostingstocktrading.ai
TASTYTRADE_ENV=sandbox
# Optional: paste refresh token from Developer Sandbox "Create Grant" (no browser OAuth needed)
TASTYTRADE_REFRESH_TOKEN=
# Must match your OAuth app scopes (space-separated)
TASTYTRADE_OAUTH_SCOPES=read trade openid

# Alpha Vantage
ALPHAVANTAGE_API_KEY=your_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tradebot

TRADING_BOT_CONFIG=config.json
